<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GradeController"
      style="-fx-background-color: #f4f7fb;">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <VBox spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.10), 14, 0, 0, 4);">
            <children>
                <Label text="QUẢN LÝ ĐIỂM SINH VIÊN" textFill="#0f172a">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>
                <Label text="Tra cứu theo mã sinh viên và quản lý bảng điểm" textFill="#64748b">
                    <font>
                        <Font size="13.0"/>
                    </font>
                </Label>
            </children>
        </VBox>

        <HBox spacing="10.0" alignment="CENTER_LEFT"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12;">
            <children>
                <Label text="Mã SV:" />
                <TextField fx:id="txtMaSV" prefWidth="240.0" promptText="Nhập mã sinh viên..." />
                <Button text="Tra cứu" onAction="#handleSearch"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            </children>
        </HBox>

        <Label fx:id="lblStudentInfo"
               text="Chưa có sinh viên được tra cứu"
               style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12; -fx-font-weight: bold; -fx-text-fill: #334155;" />

        <TableView fx:id="tableGrades" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-background-radius: 12;">
            <columns>
                <TableColumn fx:id="colSubject" text="Môn học" prefWidth="180" />
                <TableColumn fx:id="colSemester" text="Học kỳ" prefWidth="100" />
                <TableColumn fx:id="colAttendance" text="Chuyên cần" prefWidth="100" />
                <TableColumn fx:id="colProcess" text="Quá trình" prefWidth="100" />
                <TableColumn fx:id="colExam" text="Cuối kỳ" prefWidth="100" />
                <TableColumn fx:id="colFinal" text="Tổng kết" prefWidth="100" />
                <TableColumn fx:id="colLetter" text="Chữ" prefWidth="80" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="18.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12;">
            <Label fx:id="lblGPA" text="GPA Hệ 4: 0.00" style="-fx-font-weight: bold; -fx-text-fill: #2563eb;" />
            <Label fx:id="lblRank" text="Xếp loại: ---" style="-fx-font-weight: bold; -fx-text-fill: #dc2626;" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Nhập Điểm Mới" onAction="#handleAddNewGrade"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Button text="Xóa Điểm" onAction="#handleDeleteGrade"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        </HBox>
    </children>
</VBox>