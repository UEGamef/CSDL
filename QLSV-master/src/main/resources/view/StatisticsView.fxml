<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.StatisticsController"
      style="-fx-background-color: #f4f7fb;">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <VBox spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
            <children>
                <Label text="THỐNG KÊ TỔNG QUAN" textFill="#0f172a">
                    <font><Font name="System Bold" size="24.0"/></font>
                </Label>
                <Label text="Tổng hợp nhanh dữ liệu của hệ thống" textFill="#64748b" />
            </children>
        </VBox>

        <GridPane hgap="14.0" vgap="14.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0"/>
                <ColumnConstraints percentWidth="50.0"/>
            </columnConstraints>

            <children>
                <VBox spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
                    <children>
                        <Label text="Tổng số khoa" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                        <Label fx:id="lblDepartments" text="0" style="-fx-font-size: 30px; -fx-text-fill: #2563eb; -fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="1" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
                    <children>
                        <Label text="Tổng số ngành" style="-fx-font-weight: bold; -fx-text-fill: #065f46;"/>
                        <Label fx:id="lblMajors" text="0" style="-fx-font-size: 30px; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <VBox GridPane.rowIndex="1" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
                    <children>
                        <Label text="Tổng số lớp" style="-fx-font-weight: bold; -fx-text-fill: #5b21b6;"/>
                        <Label fx:id="lblClasses" text="0" style="-fx-font-size: 30px; -fx-text-fill: #8b5cf6; -fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
                    <children>
                        <Label text="Tổng số sinh viên" style="-fx-font-weight: bold; -fx-text-fill: #9a3412;"/>
                        <Label fx:id="lblStudents" text="0" style="-fx-font-size: 30px; -fx-text-fill: #f97316; -fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <VBox GridPane.rowIndex="2" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
                    <children>
                        <Label text="Tổng số giảng viên" style="-fx-font-weight: bold; -fx-text-fill: #7c2d12;"/>
                        <Label fx:id="lblLecturers" text="0" style="-fx-font-size: 30px; -fx-text-fill: #ea580c; -fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <VBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
                    <children>
                        <Label text="Tổng số môn học" style="-fx-font-weight: bold; -fx-text-fill: #991b1b;"/>
                        <Label fx:id="lblSubjects" text="0" style="-fx-font-size: 30px; -fx-text-fill: #ef4444; -fx-font-weight: bold;"/>
                    </children>
                </VBox>
            </children>
        </GridPane>
    </children>
</VBox>