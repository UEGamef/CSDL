<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GradeDialogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <GridPane hgap="10.0" vgap="12.0">
            <columnConstraints>
                <ColumnConstraints minWidth="120" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Môn học:" GridPane.rowIndex="0" />
                <ComboBox fx:id="cbSubject" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Học kỳ:" GridPane.rowIndex="1" />
                <TextField fx:id="txtSemester" promptText="Ví dụ: 2023.1" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Điểm chuyên cần:" GridPane.rowIndex="2" />
                <TextField fx:id="txtAttendance" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Điểm quá trình:" GridPane.rowIndex="3" />
                <TextField fx:id="txtProcess" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Điểm cuối kỳ:" GridPane.rowIndex="4" />
                <TextField fx:id="txtExam" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </children>
        </GridPane>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button onAction="#handleSave" style="-fx-base: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Lưu Điểm" />
            <Button onAction="#handleCancel" text="Hủy" />
        </HBox>
    </children>
</VBox>