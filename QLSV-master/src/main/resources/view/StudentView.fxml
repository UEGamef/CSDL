<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StudentController"
      style="-fx-background-color: #f4f7fb;">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <VBox spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
            <children>
                <Label text="DANH SÁCH SINH VIÊN" textFill="#0f172a">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>
                <Label text="Tìm kiếm, lọc và quản lý thông tin sinh viên" textFill="#64748b" />
            </children>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12;">
            <Label text="Tìm kiếm:" />
            <TextField fx:id="txtSearch" promptText="Mã SV, tên, SĐT, CCCD..." HBox.hgrow="ALWAYS" />
            <Label text="Lớp:" />
            <ComboBox fx:id="cbFilterClass" promptText="Tất cả lớp" prefWidth="180.0" />
        </HBox>

        <TableView fx:id="tableStudents" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-background-radius: 12;">
            <columns>
                <TableColumn fx:id="colMaSV" text="Mã SV" prefWidth="90" />
                <TableColumn fx:id="colHo" text="Họ" prefWidth="100" />
                <TableColumn fx:id="colTen" text="Tên" prefWidth="100" />
                <TableColumn fx:id="colGioiTinh" text="Giới tính" prefWidth="100" />
                <TableColumn fx:id="colSdt" text="SĐT" prefWidth="120" />
                <TableColumn fx:id="colEmail" text="Email" prefWidth="150" />
                <TableColumn fx:id="colCccd" text="CCCD" prefWidth="120" />
                <TableColumn fx:id="colNgaySinh" text="Ngày sinh" prefWidth="120" />
                <TableColumn fx:id="colDiaChi" text="Địa chỉ" prefWidth="150" />
                <TableColumn fx:id="colMaLop" text="Mã lớp" prefWidth="100" />
                <TableColumn fx:id="colTenNganh" text="Tên ngành" prefWidth="150" />
                <TableColumn fx:id="colTenKhoa" text="Tên khoa" prefWidth="150" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Thêm Mới" onAction="#handleAddStudent"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Button text="Sửa" onAction="#handleEditStudent"
                    style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Button text="Xóa" onAction="#handleDeleteStudent"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        </HBox>
    </children>
</VBox>