<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StudentController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label text="DANH SÁCH SINH VIÊN CHI TIẾT" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 5px; -fx-padding: 10;">
            <Label text="Tìm kiếm:">
                <font>
                    <Font name="System Bold" size="13.0" />
                </font>
            </Label>
            <TextField fx:id="txtSearch" promptText="Nhập Mã SV, Tên, SĐT hoặc CCCD..." HBox.hgrow="ALWAYS" />

            <Label text="Lọc theo lớp:">
                <font>
                    <Font name="System Bold" size="13.0" />
                </font>
            </Label>
            <ComboBox fx:id="cbFilterClass" promptText="Tất cả lớp" prefWidth="180.0" />
        </HBox>

        <TableView fx:id="tableStudents" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colMaSV" text="Mã SV" prefWidth="90" />
                <TableColumn fx:id="colHo" text="Họ" prefWidth="100" />
                <TableColumn fx:id="colTen" text="Tên" prefWidth="100" />
                <TableColumn fx:id="colGioiTinh" text="Giới Tính" prefWidth="100" />
                <TableColumn fx:id="colSdt" text="SĐT" prefWidth="120" />
                <TableColumn fx:id="colEmail" text="Email" prefWidth="150" />
                <TableColumn fx:id="colCccd" text="CCCD" prefWidth="120" />
                <TableColumn fx:id="colNgaySinh" text="Ngày Sinh" prefWidth="120" />
                <TableColumn fx:id="colDiaChi" text="Địa Chỉ" prefWidth="150" />
                <TableColumn fx:id="colMaLop" text="Mã Lớp" prefWidth="100" />
                <TableColumn fx:id="colTenNganh" text="Mã Ngành" prefWidth="150" />
                <TableColumn fx:id="colTenKhoa" text="Mã Khoa" prefWidth="150" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Thêm Mới" onAction="#handleAddStudent" style="-fx-base: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" />
            <Button text="Sửa" onAction="#handleEditStudent" style="-fx-base: #f1c40f; -fx-font-weight: bold;" />
            <Button text="Xóa" onAction="#handleDeleteStudent" style="-fx-base: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" />
        </HBox>
    </children>
</VBox>