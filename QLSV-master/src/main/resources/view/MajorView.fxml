<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.MajorController"
      style="-fx-background-color: #f4f7fb;">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <children>
        <VBox spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
            <children>
                <Label text="DANH SÁCH NGÀNH HỌC" textFill="#0f172a">
                    <font><Font name="System Bold" size="24.0"/></font>
                </Label>
                <Label text="Quản lý và tra cứu thông tin ngành học" textFill="#64748b" />
            </children>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12;">
            <Label text="Tìm kiếm:" />
            <TextField fx:id="txtSearch" promptText="Nhập mã ngành, tên ngành, khoa..." HBox.hgrow="ALWAYS" />
        </HBox>

        <TableView fx:id="tableMajors" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-background-radius: 12;">
            <columns>
                <TableColumn fx:id="colMaNganh" text="Mã Ngành" prefWidth="100" />
                <TableColumn fx:id="colTenNganh" text="Tên Ngành" prefWidth="220" />
                <TableColumn fx:id="colMaKhoa" text="Mã Khoa" prefWidth="120" />
                <TableColumn fx:id="colMoTa" text="Mô Tả" prefWidth="250" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Thêm Mới" onAction="#handleAddMajor"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Button text="Sửa" onAction="#handleEditMajor"
                    style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Button text="Xóa" onAction="#handleDeleteMajor"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        </HBox>
    </children>
</VBox>