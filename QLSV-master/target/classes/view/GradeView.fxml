<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.GradeController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label text="QUẢN LÝ ĐIỂM SINH VIÊN" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Chọn Sinh viên: " />
            <ComboBox fx:id="cbStudent" prefWidth="250.0" promptText="-- Chọn sinh viên --" />
        </HBox>

<!--        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 5px; -fx-padding: 10;">-->
<!--            <Label text="Tìm kiếm:">-->
<!--                <font>-->
<!--                    <Font name="System Bold" size="13.0" />-->
<!--                </font>-->
<!--            </Label>-->
<!--            <TextField fx:id="txtSearch" promptText="Nhập Mã SV, Mã môn, học kỳ..." HBox.hgrow="ALWAYS" />-->
<!--        </HBox>-->

        <TableView fx:id="tableGrades" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSubject" text="Tên Môn Học" prefWidth="180" />
                <TableColumn fx:id="colSemester" text="Học Kỳ" prefWidth="100" />
                <TableColumn fx:id="colAttendance" text="Chuyên Cần" prefWidth="100" />
                <TableColumn fx:id="colProcess" text="Điểm Quá Trình" prefWidth="120" />
                <TableColumn fx:id="colExam" text="Điểm Cuối Kỳ" prefWidth="120" />
                <TableColumn fx:id="colFinal" text="Tổng Kết (10)" prefWidth="120" />
                <TableColumn fx:id="colLetter" text="Điểm Chữ" prefWidth="80" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-background-color: #ecf0f1; -fx-padding: 10;">
            <Label fx:id="lblGPA" text="GPA Hệ 4: 0.0" style="-fx-font-weight: bold; -fx-text-fill: #2980b9;" />
            <Label fx:id="lblRank" text="Xếp loại: ---" style="-fx-font-weight: bold; -fx-text-fill: #c0392b;" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Nhập Điểm Mới" onAction="#handleAddNewGrade" style="-fx-base: #3498db; -fx-text-fill: white;" />
            <Button text="Xóa Điểm" onAction="#handleDeleteGrade" style="-fx-base: #e74c3c; -fx-text-fill: white;" />
        </HBox>
    </children>
</VBox>