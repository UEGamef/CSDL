<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.StudentAccountLookupController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label text="TRA CỨU TÀI KHOẢN SINH VIÊN" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Mã SV:" />
            <TextField fx:id="txtMaSV" promptText="Nhập mã sinh viên..." HBox.hgrow="ALWAYS" />
            <Button text="Tra cứu" onAction="#handleSearch" />
        </HBox>

        <GridPane hgap="12.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints minWidth="140.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <children>
                <Label text="Username:" GridPane.rowIndex="0" />
                <Label fx:id="lblUsername" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Họ tên:" GridPane.rowIndex="1" />
                <Label fx:id="lblFullName" text="---" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Vai trò:" GridPane.rowIndex="2" />
                <Label fx:id="lblRole" text="---" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Trạng thái:" GridPane.rowIndex="3" />
                <Label fx:id="lblActive" text="---" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Mã SV liên kết:" GridPane.rowIndex="4" />
                <Label fx:id="lblStudentId" text="---" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </children>
        </GridPane>
    </children>
</VBox>