<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.StudentDialogController"
      style="-fx-background-color: #f4f7fb;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <children>
        <VBox spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
            <children>
                <Label text="THÔNG TIN SINH VIÊN" textFill="#0f172a">
                    <font><Font name="System Bold" size="22.0"/></font>
                </Label>
                <Label text="Nhập hoặc cập nhật thông tin sinh viên" textFill="#64748b" />
            </children>
        </VBox>

        <GridPane hgap="12.0" vgap="12.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18;">
            <columnConstraints>
                <ColumnConstraints minWidth="130" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <children>
                <Label text="Mã SV:" GridPane.rowIndex="0" />
                <TextField fx:id="txtMaSV" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Họ:" GridPane.rowIndex="1" />
                <TextField fx:id="txtHo" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Tên:" GridPane.rowIndex="2" />
                <TextField fx:id="txtTen" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Giới tính:" GridPane.rowIndex="3" />
                <TextField fx:id="txtGioiTinh" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="SĐT:" GridPane.rowIndex="4" />
                <TextField fx:id="txtSdt" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="Email:" GridPane.rowIndex="5" />
                <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <Label text="CCCD:" GridPane.rowIndex="6" />
                <TextField fx:id="txtCccd" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <Label text="Ngày sinh:" GridPane.rowIndex="7" />
                <DatePicker fx:id="dpNgaySinh" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                <Label text="Địa chỉ:" GridPane.rowIndex="8" />
                <TextField fx:id="txtDiaChi" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                <Label text="Lớp:" GridPane.rowIndex="9" />
                <ComboBox fx:id="cbLop" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="9" />

                <Label text="Ngành:" GridPane.rowIndex="10" />
                <ComboBox fx:id="cbNganh" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="10" />

                <Label text="Khoa:" GridPane.rowIndex="11" />
                <ComboBox fx:id="cbKhoa" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="11" />
            </children>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Lưu" onAction="#handleSave"
                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
            <Button text="Hủy" onAction="#handleCancel"
                    style="-fx-background-color: #e2e8f0; -fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        </HBox>
    </children>
</VBox>