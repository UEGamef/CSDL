<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.StudentGradeLookupController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label text="TRA CỨU ĐIỂM SINH VIÊN" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Mã SV:" />
            <TextField fx:id="txtMaSV" promptText="Nhập mã sinh viên..." HBox.hgrow="ALWAYS" />
            <Button fx:id="btnSearch" text="Tra cứu" onAction="#handleSearch" />
        </HBox>

        <HBox spacing="20.0">
            <Label fx:id="lblGPA" text="GPA Hệ 4: 0.00" />
            <Label fx:id="lblRank" text="Xếp loại: ---" />
        </HBox>

        <TableView fx:id="tableGrades" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colSubject" text="Môn học" prefWidth="180" />
                <TableColumn fx:id="colSemester" text="Học kỳ" prefWidth="100" />
                <TableColumn fx:id="colAttendance" text="Chuyên cần" prefWidth="100" />
                <TableColumn fx:id="colProcess" text="Quá trình" prefWidth="100" />
                <TableColumn fx:id="colExam" text="Cuối kỳ" prefWidth="100" />
                <TableColumn fx:id="colFinal" text="Tổng kết" prefWidth="100" />
                <TableColumn fx:id="colLetter" text="Chữ" prefWidth="80" />
            </columns>
        </TableView>
    </children>
</VBox>