<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.MajorController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <children>
        <Label text="DANH SÁCH NGÀNH HỌC" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="22.0" />
            </font>
        </Label>

        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-background-radius: 5px; -fx-padding: 10;">
            <Label text="Tìm kiếm:">
                <font>
                    <Font name="System Bold" size="13.0" />
                </font>
            </Label>
            <TextField fx:id="txtSearch" promptText="Nhập mã ngành, tên ngành, khoa..." HBox.hgrow="ALWAYS" />
        </HBox>

        <TableView fx:id="tableMajors" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colMaNganh" text="Mã Ngành" prefWidth="100" />
                <TableColumn fx:id="colTenNganh" text="Tên Ngành" prefWidth="220" />
                <TableColumn fx:id="colMaKhoa" text="Mã Khoa" prefWidth="120" />
                <TableColumn fx:id="colMoTa" text="Mô Tả" prefWidth="250" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button text="Thêm Mới" onAction="#handleAddMajor" style="-fx-base: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" />
            <Button text="Sửa" onAction="#handleEditMajor" style="-fx-base: #f1c40f; -fx-font-weight: bold;" />
            <Button text="Xóa" onAction="#handleDeleteMajor" style="-fx-base: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" />
        </HBox>
    </children>
</VBox>