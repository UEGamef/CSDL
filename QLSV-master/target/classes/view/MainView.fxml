<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.MainViewController"
            prefWidth="1280.0"
            prefHeight="760.0">

    <children>
        <VBox AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">

            <children>
                <HBox alignment="CENTER_LEFT"
                      spacing="12.0"
                      prefHeight="74.0"
                      style="-fx-background-color: linear-gradient(to right, #0f172a, #1e293b);">
                    <padding>
                        <Insets top="14.0" right="20.0" bottom="14.0" left="20.0"/>
                    </padding>

                    <children>
                        <VBox spacing="2.0">
                            <children>
                                <Label text="SLinkV2 - Quản lý sinh viên" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="20.0"/>
                                    </font>
                                </Label>
                                <Label text="Sinh viên • Lớp • Điểm • Tài khoản • Thống kê" textFill="#cbd5e1">
                                    <font>
                                        <Font size="12.0"/>
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <Label fx:id="lblCurrentUser" text="Đăng nhập: ---" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0"/>
                            </font>
                        </Label>

                        <Button fx:id="btnAccountManager"
                                text="Tài khoản"
                                onAction="#handleOpenAccountWindow"
                                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>

                        <Button text="Đăng xuất"
                                onAction="#handleLogout"
                                style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                    </children>
                </HBox>

                <TabPane fx:id="tabPane"
                         tabClosingPolicy="UNAVAILABLE"
                         VBox.vgrow="ALWAYS"
                         style="-fx-background-color: #f4f7fb;">
                    <tabs>
                        <Tab fx:id="tabDepartment" text="Khoa">
                            <content><fx:include source="DepartmentView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabMajor" text="Ngành">
                            <content><fx:include source="MajorView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabClass" text="Lớp">
                            <content><fx:include source="ClassView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabStudent" text="Sinh viên">
                            <content><fx:include source="StudentView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabLecturer" text="Giảng viên">
                            <content><fx:include source="LecturerView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabSubject" text="Môn học">
                            <content><fx:include source="SubjectView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabGrade" text="Điểm">
                            <content><fx:include source="GradeView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabStudentGradeLookup" text="Tra cứu điểm">
                            <content><fx:include source="StudentGradeLookupView.fxml" /></content>
                        </Tab>
                        <Tab fx:id="tabStatistics" text="Thống kê">
                            <content><fx:include source="StatisticsView.fxml" /></content>
                        </Tab>
                    </tabs>
                </TabPane>
            </children>
        </VBox>
    </children>
</AnchorPane>